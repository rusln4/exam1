<Window x:Class="AprilExam1.ClientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AprilExam1"
        mc:Ignorable="d"
        Title="Каталог" MinHeight="850" MinWidth="1200" MaxHeight="850" MaxWidth="1200" WindowStartupLocation="CenterScreen">
    <Grid>
        <ListBox x:Name="ProductsListBox" HorizontalAlignment="Stretch">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Black" BorderThickness="1" Margin="5" Padding="5">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="White"/>
                                <Style.Triggers>
                                     <!-- Скидка более 15% -->
                                     <DataTrigger Binding="{Binding IsHighDiscount}" Value="True">
                                         <Setter Property="Background" Value="#2E8B57"/>
                                     </DataTrigger>
                                     <!-- Товара нет на складе (голубой цвет) -->
                                     <DataTrigger Binding="{Binding IsInStock}" Value="False">
                                         <Setter Property="Background" Value="LightBlue"/>
                                     </DataTrigger>
                                 </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="700"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>

                            <Image Source="{Binding FullImagePath}" Grid.Column="0" Height="120" Width="120" Margin="5"></Image>
                                
                            <StackPanel Grid.Column="1" Margin="10 0">
                                <TextBlock FontWeight="Bold" FontSize="14">
                                    <Run Text="{Binding Category.Name}"></Run>
                                    <Run Text=" | "></Run>
                                    <Run Text="{Binding Name}"></Run>
                                </TextBlock>
                                <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Margin="0 5 0 0"></TextBlock>
                                <TextBlock Text="{Binding Manufacture.Name, StringFormat='Производитель: {0}'}" Margin="0 2 0 0"></TextBlock>
                                <TextBlock Text="{Binding Supplire.Name, StringFormat='Поставщик: {0}'}" Margin="0 2 0 0"></TextBlock>
                                
                                <!-- Логика отображения цены -->
                                <StackPanel Orientation="Horizontal" Margin="0 2 0 0">
                                    <TextBlock Text="Цена: "/>
                                    <TextBlock Text="{Binding Price}" Foreground="Red" TextDecorations="Strikethrough" Margin="0,0,5,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Discount}" Value="0">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding FinalPrice, StringFormat='{0:N2}'}" Foreground="Black"/>
                                </StackPanel>

                                <TextBlock Text="{Binding Unit, StringFormat='Единица измерения: {0}'}" Margin="0 2 0 0"></TextBlock>
                                <TextBlock Text="{Binding CountInStorage, StringFormat='Количество на складе: {0}'}" Margin="0 2 0 0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="Скидка: " TextWrapping="Wrap" TextAlignment="Center" FontSize="10"></TextBlock>
                                <TextBlock Text="{Binding Discount, StringFormat=' {0}%'}" FontWeight="Bold" HorizontalAlignment="Center"></TextBlock>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
