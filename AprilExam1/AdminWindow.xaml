<Window x:Class="AprilExam1.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AprilExam1"
        mc:Ignorable="d"
        Title="Каталог" Icon="/Images/Icon.png" MinHeight="850" MinWidth="1200" MaxHeight="850" MaxWidth="1200" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>
        <Button Grid.Row="0" Height="40" Width="250" x:Name="CreateNewProductBtn" FontSize="20" FontWeight="Bold" Content="Создать новый товар" Click="CreateNewProductBtn_Click"></Button>
        <ListBox Grid.Row="1" HorizontalAlignment="Stretch" x:Name="ListBoxProducts">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderThickness="1" BorderBrush="Black" Margin="5" Padding="5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"></ColumnDefinition>
                                <ColumnDefinition Width="600"></ColumnDefinition>
                                <ColumnDefinition Width="150"></ColumnDefinition>
                            </Grid.ColumnDefinitions>

                            <Image Source="{Binding FullImagePath}" Grid.Column="0" Height="120" Width="120" Margin="5"></Image>

                            <StackPanel Grid.Column="1" Margin="10 0">
                                <TextBlock FontWeight="Bold" FontSize="14">
                                    <Run Text="{Binding Category.Name}"></Run>
                                    <Run Text=" | "></Run>
                                    <Run Text="{Binding Name}"></Run>
                                </TextBlock>

                                <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Margin="0 5 0 0"></TextBlock>
                                <TextBlock Text="{Binding Manufacture.Name, StringFormat='Производитель: {0}'}" Margin="0 2 0 0"></TextBlock>
                                <TextBlock Text="{Binding Supplire.Name, StringFormat='Поставщик: {0}'}" Margin="0 2 0 0"></TextBlock>
                                <TextBlock Text="{Binding Price, StringFormat='Цена: {0} руб'}" Margin="0 2 0 0"></TextBlock>
                                <TextBlock Text="{Binding Unit, StringFormat='Единицы измерения: {0}'}" Margin="0 2 0 0"></TextBlock>
                                <TextBlock Text="{Binding CountInStorage, StringFormat='Количство на складе: {0}'}"></TextBlock>
                            </StackPanel>

                            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="Действующая скидка:" TextAlignment="Center" FontSize="10"></TextBlock>
                                <TextBlock Text="{Binding Discount, StringFormat=' {0}%'}" FontWeight="Bold" HorizontalAlignment="Center"></TextBlock>
                                
                            </StackPanel>
                            
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
