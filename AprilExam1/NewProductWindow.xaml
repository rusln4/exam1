<Window x:Class="AprilExam1.NewProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AprilExam1"
        mc:Ignorable="d"
        Title="Создание товара" MinHeight="650" MinWidth="800" MaxHeight="650" MaxWidth="800" WindowStartupLocation="CenterScreen">
    
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock FontSize="20" FontWeight="Bold">Создание товара</TextBlock>
            <TextBlock FontSize="16" Text="Название:" Margin="0 20 0 0"></TextBlock>
            <TextBox x:Name="NameTextBox"></TextBox>
            <TextBlock FontSize="16" Text="Описание:" Margin="0 20 0 0"></TextBlock>
            <TextBox x:Name="DescTextBox" TextWrapping="Wrap"></TextBox>
            <TextBlock FontSize="16" Text="Цена:" Margin="0 20 0 0"></TextBlock>
            <TextBox x:Name="PriceTextBox"></TextBox>
            <TextBlock FontSize="16" Text="Скидка %:" Margin="0 20 0 0"></TextBlock>
            <TextBox x:Name="DiscountTextBox"></TextBox>
            <TextBlock FontSize="16" Text="Категория::" Margin="0 20 0 0"></TextBlock>
            <ComboBox x:Name="CategoryComboBox" DisplayMemberPath="Name" SelectedValuePath="Id"></ComboBox>
            <TextBlock FontSize="16" Text="Производитель::" Margin="0 20 0 0"></TextBlock>
            <ComboBox x:Name="ManufactureComboBox" DisplayMemberPath="Name" SelectedValuePath="Id"></ComboBox>
            <TextBlock FontSize="16" Text="Поставщик::" Margin="0 20 0 0"></TextBlock>
            <ComboBox x:Name="SuplierComboBox" DisplayMemberPath="Name" SelectedValuePath="Id"></ComboBox>

            <Button x:Name="AddNewProductButton" Margin="0 20 0 0" Height="30" Content="Добавить" Click="AddNewProductButton_Click"></Button>

        </StackPanel>
        
    </Grid>
</Window>
