<Window x:Class="AprilExam1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AprilExam1"
        mc:Ignorable="d"
        Title="Вход" Icon="/Images/Icon.png" MinHeight="850" MinWidth="1200" MaxHeight="850" MaxWidth="1200" WindowStartupLocation="CenterScreen">
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="600">
            <TextBlock Text="Авторизация" FontSize="40" FontWeight="Bold" Margin="0 0 0 20" HorizontalAlignment="Center"></TextBlock>
            <TextBlock Text="Почта:" FontSize="30" FontWeight="Bold" Margin="0 5 0 15"></TextBlock>
            <TextBox x:Name="EmailTextBox" Padding="5" Margin="0 0 0 5"></TextBox>

            <TextBlock Text="Пароль:" FontSize="30" FontWeight="Bold" Margin="0 20 0 15"></TextBlock>
            <TextBox x:Name="PasswordTextBox" Padding="5" Margin="0 0 0 5"></TextBox>

            <Button x:Name="EnterButton" Content="Войти" Margin="0 20 0 0" Background="LightGreen" Width="300" Height="50" Click="EnterButton_Click"></Button>
            
        </StackPanel>

    </Grid>
</Window>
